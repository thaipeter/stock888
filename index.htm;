            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label" style="color:rgba(255,255,255,.45);font-size:.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase">หัวข้อ</label>
                    <input type="text" id="noteTitle" class="form-control" placeholder="เช่น สั่งซื้อของ, แจ้งช่าง..." style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#fff;border-radius:10px">
                </div>
                <div class="mb-3">
                    <label class="form-label" style="color:rgba(255,255,255,.45);font-size:.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase">รายละเอียด</label>
                    <textarea id="noteBody" class="form-control" rows="4" placeholder="เขียนโน้ตของคุณ..." style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#fff;border-radius:10px;resize:none"></textarea>
                </div>
                <div class="mb-2">
                    <label class="form-label" style="color:rgba(255,255,255,.45);font-size:.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase">สีโน้ต</label>
                    <div class="d-flex gap-2" id="noteColorPicker">
                        <div onclick="selectNoteColor('#fbbf24')" style="width:28px;height:28px;border-radius:50%;background:#fbbf24;cursor:pointer;border:2px solid rgba(255,255,255,.5)" data-color="#fbbf24"></div>
                        <div onclick="selectNoteColor('#a78bfa')" style="width:28px;height:28px;border-radius:50%;background:#a78bfa;cursor:pointer;border:2px solid transparent" data-color="#a78bfa"></div>
                        <div onclick="selectNoteColor('#34d399')" style="width:28px;height:28px;border-radius:50%;background:#34d399;cursor:pointer;border:2px solid transparent" data-color="#34d399"></div>
                        <div onclick="selectNoteColor('#f87171')" style="width:28px;height:28px;border-radius:50%;background:#f87171;cursor:pointer;border:2px solid transparent" data-color="#f87171"></div>
                        <div onclick="selectNoteColor('#67e8f9')" style="width:28px;height:28px;border-radius:50%;background:#67e8f9;cursor:pointer;border:2px solid transparent" data-color="#67e8f9"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,.08);padding:12px 20px">
                <button type="button" class="btn btn-sm" data-bs-dismiss="modal" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.6);border-radius:8px">ยกเลิก</button>
                <button type="button" class="btn btn-sm fw-bold" onclick="saveNote()" style="background:linear-gradient(135deg,#f59e0b,#fbbf24);border:none;color:#000;border-radius:8px;padding:6px 20px">บันทึก</button>
            </div>
        </div>
    </div>
</div>

</body>
</html>
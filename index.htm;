            }
            logs.forEach(log => {
                const meta = AUDIT_TYPE_META[log.type] || { label: log.type, badge: 'bg-secondary bg-opacity-10 text-secondary', icon: 'fa-circle' };
                const statusBadge = log.status === 'SUCCESS'
